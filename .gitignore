# K-Ruoka recipe catalog (c) Kesko -- raw crawl includes their written
# instructions; never publish raw/derived extracts, only our own scripts
# and the freshly-authored kruoka_recipes.json (translated names, our own
# steps, their factual ingredient/macro data only)
scraper/recipes_raw.json
scraper/reseptit_*.json
scraper/reseptit_*.png
scraper/recipe_detail_raw.html
scraper/selected_recipes.json
scraper/coverage_clean.json

# Grab-and-go: keep only the final curated grabgo_recommendations.json;
# the raw crawl dumps are regenerable intermediates, not final output.
scraper/grabgo_candidates_raw.json
scraper/grabgo_details_raw.json

# Budget Bytes recipes (c) Budget Bytes -- raw scrape includes their
# written descriptions/instructions; never publish raw/derived extracts, only
# our own scripts and the freshly-authored airfryer_recipes.json/quick_recipes.json
# (their name/nutrition/ingredients as facts, our own steps)
scraper/budgetbytes_raw.json
scraper/budgetbytes_quick_raw.json

# Fork To Spoon air-fryer recipes (c) Fork To Spoon -- same policy as the
# Budget Bytes raw files above: only our own scripts and the
# freshly-authored forktospoon_recipes.json get published
scraper/forktospoon_airfryer_raw.json

